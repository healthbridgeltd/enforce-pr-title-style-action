{
  "name": "@healthbridgeltd/enforce-pr-title-style-action",
  "version": "2.0.0",
  "description": "Checks that a Pull Request includes a Jira Issue key",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build src/index.ts -o dist --source-map",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "author": "healthbridgeltd",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.3.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "9.39.2",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.0",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
