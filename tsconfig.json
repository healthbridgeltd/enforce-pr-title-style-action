{
  "compilerOptions": {
    "types": ["node", "jest"],
    "target": "esnext",
    "module": "nodenext",
    "outDir": "./dist" ,
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true, 
    "strictNullChecks": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts",]
}
